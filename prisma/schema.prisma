generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cities   City[]
  settings ProjectSetting[]

  @@map("projects")
}

model ProjectSetting {
  projectId Int     @map("project_id")
  key       String
  value     String  @db.Text
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, key])
  @@map("project_settings")
}

model City {
  id             Int      @id @default(autoincrement())
  projectId      Int      @default(1) @map("project_id")
  slug           String
  name           String
  twogisFirmId   String?  @map("twogis_firm_id")
  yandexOrgId    String?  @map("yandex_org_id")
  siteUrl        String?  @map("site_url")
  isActive       Boolean  @default(true) @map("is_active")
  configOverride Json?    @map("config_override")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Restrict)
  reviews  Review[]
  statuses SourceStatus[]

  @@unique([projectId, slug])
  @@index([slug])
  @@map("cities")
}

model Review {
  id          String   @id
  source      String
  externalId  String   @map("external_id")
  cityId      Int      @map("city_id")
  city        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  author      String
  avatarUrl   String?  @map("avatar_url")
  rating      Int
  text        String   @db.Text
  reply       String?  @db.Text
  reviewUrl   String?  @map("review_url")
  publishedAt DateTime @map("published_at")
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  isHidden    Boolean  @default(false) @map("is_hidden")

  @@unique([source, externalId])
  @@index([cityId, isHidden, publishedAt(sort: Desc)])
  @@index([source])
  @@index([lastSeenAt])
  @@map("reviews")
}

model SourceStatus {
  id            Int       @id @default(autoincrement())
  cityId        Int       @map("city_id")
  city          City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  source        String
  lastSuccessAt DateTime? @map("last_success_at")
  lastErrorAt   DateTime? @map("last_error_at")
  lastError     String?   @map("last_error") @db.Text
  reviewsCount  Int       @default(0) @map("reviews_count")
  averageRating Float?    @map("average_rating")

  @@unique([cityId, source])
  @@map("source_status")
}

model Setting {
  key   String @id
  value String @db.Text

  @@map("settings")
}

model Alert {
  id             Int       @id @default(autoincrement())
  level          String    // 'info' | 'warning' | 'error'
  title          String
  message        String    @db.Text
  dedupeKey      String    @map("dedupe_key")
  context        Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  acknowledgedAt DateTime? @map("acknowledged_at")

  @@index([acknowledgedAt, createdAt(sort: Desc)])
  @@index([dedupeKey])
  @@map("alerts")
}
